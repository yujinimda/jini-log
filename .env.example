# 사이트 (grilling 확정: 도메인·이름은 배포 시점 주입)
SITE_URL=http://localhost:3000
SITE_NAME=jini-log

# 운영자 (허용되는 유일한 GitHub 계정)
ADMIN_GITHUB_LOGIN=yujinimda

# Auth.js — GitHub OAuth App (콜백: {SITE_URL}/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET= # openssl rand -base64 32

# 콘텐츠 커밋 — fine-grained PAT (jini-log contents read/write)
GITHUB_CONTENT_TOKEN=
GITHUB_REPO=yujinimda/jini-log

# 조회수 — Supabase (서버 전용, 브라우저 노출 금지)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 배포 상태 폴링 — Vercel (research R10)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
